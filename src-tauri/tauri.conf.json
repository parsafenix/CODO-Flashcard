{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CODO Flashcard",
  "version": "0.5.0",
  "identifier": "com.codo.flashcard",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CODO: Flashcard",
        "width": 1400,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/128x128.png",
      "icons/256x256.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerIcon": "icons/icon.ico",
        "startMenuFolder": "CODO"
      }
    }
  }
}
